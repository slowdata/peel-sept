---
interface Props {
  source: string;
  sourceCount?: number;
}

const { source, sourceCount = 1 } = Astro.props;
const consensus = sourceCount > 1;
---

<span class:list={['source-badge', { consensus }]}>
  {consensus ? '★' : ''}
  <span>{source}</span>
  {consensus && <span>· {sourceCount} fontes</span>}
</span>
