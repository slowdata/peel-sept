---
import AlbumCard from './AlbumCard.astro';
import PlaylistPlayer from './PlaylistPlayer.astro';
import ShareButtons from './ShareButtons.astro';
import TrackCard from './TrackCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import type { Issue } from '../data/issues';
import { formatDateRange, localizedIssuePath, normalizeLocale, t, weekLabel, type Locale } from '../i18n';

interface Props {
  issue: Issue;
  issues: Issue[];
  locale: Locale;
  isIndex?: boolean;
}

const { issue, issues, isIndex = false } = Astro.props;
const locale = normalizeLocale(Astro.currentLocale ?? Astro.props.locale);
// A playlist Spotify é rolante (um só URL, as faixas trocam). Só faz sentido
// na edição mais recente; no histórico mostramos uma nota e as faixas abrem
// soltas no Spotify (TrackCard já liga cada título).
const latestWeek = issues.map((item) => item.week).sort().at(-1);
const isLatest = issue.week === latestWeek;
const issueDateRange = formatDateRange(issue.start_date, issue.end_date, locale);
const issueWeekLabel = weekLabel(locale, issue);
const title = `Peel Sept — ${issueWeekLabel}`;
const description = `${issueDateRange}: ${t(locale, 'site.description')}`;
const baseUrl = Astro.site ?? Astro.url;
const shareUrl = new URL(localizedIssuePath(locale, issue), baseUrl).toString();
const instagramImageUrl = new URL(`/ig/${issue.week}.png`, baseUrl).toString();
const twitterUrl = `https://twitter.com/intent/tweet?${new URLSearchParams({
  text: t(locale, 'share.tweetText', { week: issueWeekLabel }),
  url: shareUrl,
}).toString()}`;
const ratingLabels = {
  empty: t(locale, 'rating.empty'),
  aria: t(locale, 'rating.aria'),
  ban: t(locale, 'rating.ban'),
  skip: t(locale, 'rating.skip'),
  meh: t(locale, 'rating.meh'),
  like: t(locale, 'rating.like'),
  love: t(locale, 'rating.love'),
};
---

<BaseLayout
  issue={issue}
  issues={issues}
  locale={locale}
  pathIssue={isIndex ? null : issue}
  title={title}
  description={description}
>
  <header>
    <h1 class="mark">Peel <em>Sept</em></h1>
    <p class="lede">{t(locale, 'hero.lede')}</p>
    <div class="hero-actions">
      <p class="mono dates">{issueDateRange}</p>
    </div>
    <ShareButtons
      twitterUrl={twitterUrl}
      instagramImageUrl={instagramImageUrl}
      instagramDownloadName={`peel-sept-${issue.week}-instagram.png`}
      nativeTitle={title}
      nativeText={t(locale, 'share.nativeText', { week: issueWeekLabel })}
      nativeUrl={shareUrl}
      kicker={t(locale, 'share.kicker')}
      xLabel={t(locale, 'share.x')}
      nativeLabel={t(locale, 'share.native')}
      nativeAriaLabel={t(locale, 'share.nativeAria')}
      instagramLabel={t(locale, 'share.instagram')}
    />
    {
      isLatest ? (
        <PlaylistPlayer
          playlistUrl={issue.playlist_url}
          ariaLabel={t(locale, 'player.aria')}
          kicker={t(locale, 'player.kicker')}
          title={t(locale, 'player.title')}
          copy={t(locale, 'player.copy')}
          listenLabel={t(locale, 'player.listen')}
          openLabel={t(locale, 'player.open')}
          loadAriaLabel={t(locale, 'player.loadAria')}
        />
      ) : (
        <p class="archive-note">{t(locale, 'player.archiveNote')}</p>
      )
    }
  </header>

  <section aria-labelledby="tracks-heading">
    <div class="sec-head">
      <h2 id="tracks-heading">{t(locale, 'sections.tracks')}</h2>
      <span class="mono">{t(locale, 'sections.tracksMeta', { count: issue.tracks.length })}</span>
    </div>
    <div class="playlist">
      {
        issue.tracks.map((track) => (
          <TrackCard
            track={track}
            week={issue.week}
            ratingLabels={ratingLabels}
            consensusLabel={t(locale, 'source.consensus', { count: track.source_count })}
          />
        ))
      }
    </div>
  </section>

  <section aria-labelledby="albums-heading">
    <div class="sec-head">
      <h2 id="albums-heading">{t(locale, 'sections.albums')}</h2>
      <span class="mono">{t(locale, 'sections.albumsMeta', { count: issue.albums.length })}</span>
    </div>
    <div class="albgrid">
      {issue.albums.map((album) => <AlbumCard album={album} />)}
    </div>
    <p class="alb-cap">{t(locale, 'sections.albumsCaption')}</p>
  </section>

  <section aria-labelledby="sources-heading">
    <div class="sec-head">
      <h2 id="sources-heading">{t(locale, 'sections.sources')}</h2>
      <span class="mono">{t(locale, 'sections.sourcesMeta')}</span>
    </div>
    <div class="source-strip">
      {
        issue.sources.map((source) =>
          source.url ? (
            <a class="chip" href={source.url} target="_blank" rel="noopener noreferrer">
              {source.name}
            </a>
          ) : (
            <span class="chip">{source.name}</span>
          )
        )
      }
    </div>
  </section>
</BaseLayout>
