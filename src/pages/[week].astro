---
import AlbumCard from '../components/AlbumCard.astro';
import PlaylistPlayer from '../components/PlaylistPlayer.astro';
import TrackCard from '../components/TrackCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { issues, type Issue } from '../data/issues';

export function getStaticPaths() {
  return issues.map((issue) => ({
    params: { week: issue.week },
    props: { issue },
  }));
}

interface Props {
  issue: Issue;
}

const { issue } = Astro.props;
const title = `Peel Sept — ${issue.label}`;
const description = `${issue.date_range}: sete faixas e sete álbuns em rotação.`;
---

<BaseLayout issue={issue} issues={issues} title={title} description={description}>
  <header>
    <h1 class="mark">Peel <em>Sept</em></h1>
    <p class="lede">
      Sete músicas, escolhidas e avaliadas todas as semanas. Um diário sonoro,
      atualizado ao domingo. Sem algoritmos, sem bolhas.
    </p>
    <div class="hero-actions">
      <p class="mono dates">{issue.date_range}</p>
    </div>
    <PlaylistPlayer playlistUrl={issue.playlist_url} />
  </header>

  <section aria-labelledby="tracks-heading">
    <div class="sec-head">
      <h2 id="tracks-heading">A Semana</h2>
      <span class="mono">{issue.tracks.length} faixas · à mão</span>
    </div>
    <div class="playlist">
      {issue.tracks.map((track) => <TrackCard track={track} week={issue.week} />)}
    </div>
  </section>

  <section aria-labelledby="albums-heading">
    <div class="sec-head">
      <h2 id="albums-heading">Em Rotação</h2>
      <span class="mono">{issue.albums.length} álbuns</span>
    </div>
    <div class="albgrid">
      {issue.albums.map((album) => <AlbumCard album={album} />)}
    </div>
    <p class="alb-cap">
      Sete álbuns a ouvir de fio a pavio. Quando há consenso entre fontes, o
      quadrado ganha destaque.
    </p>
  </section>

  <section aria-labelledby="sources-heading">
    <div class="sec-head">
      <h2 id="sources-heading">Fontes</h2>
      <span class="mono">críticos · labels · rádio</span>
    </div>
    <div class="source-strip">
      {issue.sources.map((source) => <span class="chip">{source}</span>)}
    </div>
  </section>
</BaseLayout>
