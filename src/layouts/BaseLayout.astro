---
import type { Issue } from '../data/issues';
import {
  alternateLinks,
  localizedIssuePath,
  normalizeLocale,
  t,
  weekLabel,
  type Locale,
} from '../i18n';

interface Props {
  title?: string;
  description?: string;
  issue: Issue;
  issues: Issue[];
  locale?: Locale;
  pathIssue?: Issue | null;
}

const locale = normalizeLocale(Astro.props.locale ?? Astro.currentLocale);
const {
  title = t(locale, 'site.title'),
  description = t(locale, 'site.description'),
  issue,
  issues,
} = Astro.props;
const pathIssue = Astro.props.pathIssue === undefined ? issue : Astro.props.pathIssue;
const baseUrl = Astro.site ?? Astro.url;
const canonical = new URL(localizedIssuePath(locale, pathIssue ?? undefined), baseUrl).toString();
const socialImage = new URL(`/og/${issue.week}.png`, baseUrl).toString();
const alternates = alternateLinks(pathIssue ?? undefined, baseUrl);
const otherLocale: Locale = locale === 'en' ? 'pt' : 'en';
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alternates.map((item) => <link rel="alternate" hreflang={item.locale} href={item.href} />)}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Peel Sept" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

  </head>
  <body>
    <div class="wrap">
      <div class="topbar">
        <a class="mono site-id" href={localizedIssuePath(locale)}>peel.sept.pt</a>
        <div class="top-meta">
          <span class="mono">{weekLabel(locale, issue)}</span>
          <a class="mono locale-switch" href={localizedIssuePath(otherLocale, pathIssue ?? undefined)}>
            {t(locale, 'nav.language')}
          </a>
        </div>
      </div>

      <slot />

      <footer>
        <p class="thanks">
          <span class="ethos">{t(locale, 'footer.ethos')}</span>
          {t(locale, 'footer.manifesto')}
        </p>
        <p class="manifesto">{t(locale, 'footer.copy')} <span>{t(locale, 'hero.peelNoise')}</span></p>
        <nav class="archive" aria-label={t(locale, 'nav.archiveAria')}>
          <span class="mono">{t(locale, 'nav.archive')}</span>
          <div>
            {
              issues.map((item) => (
                <a class={item.week === issue.week ? 'active' : ''} href={localizedIssuePath(locale, item)}>
                  {item.week}
                </a>
              ))
            }
          </div>
        </nav>
        <div class="botbar">
          <span class="mono">© 2026 Peel Sept</span>
          <span class="mono">{t(locale, 'footer.made')}</span>
        </div>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  @font-face {
    font-family: 'Fraunces';
    src: url('../assets/fonts/Fraunces-Variable.ttf') format('truetype');
    font-style: normal;
    font-weight: 400 600;
    font-display: swap;
  }

  @font-face {
    font-family: 'Fraunces';
    src: url('../assets/fonts/Fraunces-Italic-Variable.ttf') format('truetype');
    font-style: italic;
    font-weight: 400 600;
    font-display: swap;
  }

  @font-face {
    font-family: 'Syne';
    src: url('../assets/fonts/Syne-Variable.ttf') format('truetype');
    font-style: normal;
    font-weight: 400 700;
    font-display: swap;
  }

  @font-face {
    font-family: 'Geist Mono';
    src: url('../assets/fonts/GeistMono-Variable.ttf') format('truetype');
    font-style: normal;
    font-weight: 400 500;
    font-display: swap;
  }

  :root {
    --bg: #0a0a0a;
    --fg: #f3f1ee;
    --muted: #8d8a86;
    --faint: #5a5854;
    --line: #211f1d;
    --hover: #131211;
    --accent: #e2895a;
    --maxw: 720px;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    background: var(--bg);
  }

  body {
    font-family: 'Syne', system-ui, sans-serif;
    background: var(--bg);
    color: var(--fg);
    line-height: 1.6;
    letter-spacing: 0.3px;
    padding: 0 28px;
    -webkit-tap-highlight-color: transparent;
  }

  a {
    color: inherit;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .wrap {
    max-width: var(--maxw);
    margin: 0 auto;
  }

  .mono {
    font-family: 'Geist Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 11.5px;
    color: var(--faint);
  }

  .topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    padding: 56px 0 64px;
  }

  .site-id {
    text-decoration: none;
  }

  .top-meta {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 14px;
  }

  .locale-switch {
    color: var(--muted);
    text-decoration: none;
  }

  .locale-switch:hover,
  .locale-switch:focus-visible {
    color: var(--accent);
    outline: none;
  }

  .mark {
    font-family: 'Fraunces', Georgia, serif;
    font-optical-sizing: auto;
    font-size: 62px;
    font-weight: 500;
    letter-spacing: -1.4px;
    line-height: 1;
  }

  .mark em {
    color: var(--muted);
    font-style: italic;
  }

  .lede {
    max-width: 26em;
    margin-top: 18px;
    color: var(--muted);
    font-size: 16.5px;
    font-weight: 400;
    line-height: 1.6;
    letter-spacing: 0.3px;
  }

  .dates {
    margin-top: 0;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px;
    margin-top: 20px;
  }

  .sec-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 20px;
    margin: 92px 0 8px;
  }

  .sec-head h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-optical-sizing: auto;
    font-size: 29px;
    font-weight: 500;
    letter-spacing: -0.4px;
  }

  .playlist {
    border-bottom: 1px solid var(--line);
  }

  .row {
    display: grid;
    grid-template-columns: 40px 1fr 150px;
    align-items: center;
    gap: 20px;
    padding: 22px 0;
    border-top: 1px solid var(--line);
  }

  .num {
    font-family: 'Geist Mono', monospace;
    color: var(--faint);
    font-size: 12px;
  }

  .title {
    font-size: 15.5px;
    font-weight: 500;
    line-height: 1.6;
    letter-spacing: 0.3px;
  }

  .artist {
    margin-top: 2px;
    color: var(--muted);
    font-size: 13.5px;
    line-height: 1.6;
    letter-spacing: 0.3px;
  }

  .src {
    color: var(--faint);
  }

  .source-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--faint);
  }

  .source-badge.consensus {
    color: var(--accent);
  }

  .rate {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 7px;
  }

  .bar {
    display: flex;
    gap: 4px;
  }

  .seg {
    width: 18px;
    height: 4px;
    padding: 0;
    cursor: pointer;
    border: none;
    border-radius: 3px;
    background: var(--line);
    transition:
      background 0.14s ease,
      transform 0.14s ease;
  }

  .seg:hover,
  .seg:focus-visible {
    transform: scaleY(1.6);
    outline: none;
  }

  .seg:focus-visible {
    box-shadow: 0 0 0 2px var(--accent);
  }

  .seg.on {
    background: var(--fg);
  }

  .row[data-rated='love'] .seg.on,
  .row[data-rated='like'] .seg.on {
    background: var(--accent);
  }

  .rlabel {
    font-family: 'Geist Mono', monospace;
    color: var(--faint);
    font-size: 10.5px;
    letter-spacing: 1.6px;
    text-transform: uppercase;
    transition: color 0.14s ease;
  }

  .row[data-rated] .rlabel {
    color: var(--muted);
  }

  .albgrid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 12px;
    margin-top: 26px;
  }

  .alb {
    position: relative;
    display: grid;
    aspect-ratio: 1;
    place-items: center;
    border: 1px dashed var(--line);
    border-radius: 10px;
    text-decoration: none;
    transition:
      border-color 0.18s ease,
      background 0.18s ease;
  }

  .alb:hover,
  .alb:focus-visible {
    border-color: var(--faint);
    background: var(--hover);
    outline: none;
  }

  .alb .n {
    font-family: 'Geist Mono', monospace;
    color: var(--faint);
    font-size: 11px;
  }

  .alb .tip {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    max-width: 240px;
    padding: 5px 9px;
    transform: translateX(-50%);
    border-radius: 6px;
    opacity: 0;
    background: var(--fg);
    color: var(--bg);
    font-size: 11px;
    font-weight: 500;
    pointer-events: none;
    text-align: center;
    transition: opacity 0.15s ease;
    white-space: nowrap;
    z-index: 2;
  }

  .alb:hover .tip,
  .alb:focus-visible .tip {
    opacity: 1;
  }

  .alb.consensus {
    border-color: color-mix(in srgb, var(--accent), var(--line) 45%);
  }

  .alb-cap {
    margin-top: 22px;
    color: var(--muted);
    font-size: 14.5px;
    line-height: 1.6;
    letter-spacing: 0.3px;
  }

  .source-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 30px;
  }

  .chip {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 5px 9px;
    color: var(--muted);
    font-size: 12px;
  }

  footer {
    margin: 100px 0 70px;
    padding-top: 30px;
    border-top: 1px solid var(--line);
  }

  .thanks {
    max-width: 36em;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.6;
  }

  .ethos {
    color: var(--fg);
    font-family: 'Fraunces', Georgia, serif;
    font-optical-sizing: auto;
    font-style: italic;
    font-size: 1.08em;
  }

  .manifesto {
    margin-top: 16px;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.6;
    letter-spacing: 0.3px;
  }

  .manifesto span {
    color: var(--fg);
  }

  .archive {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    margin-top: 34px;
    padding-top: 22px;
    border-top: 1px solid var(--line);
  }

  .archive div {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 10px;
  }

  .archive a {
    color: var(--muted);
    font-size: 13px;
  }

  .archive a.active {
    color: var(--accent);
  }

  .botbar {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    margin-top: 30px;
  }

  @media (max-width: 560px) {
    body {
      padding: 0 20px;
    }

    .topbar,
    .top-meta,
    .botbar,
    .archive {
      align-items: flex-start;
      flex-direction: column;
    }

    .topbar {
      padding: 38px 0 52px;
    }

    .mark {
      font-size: 44px;
      letter-spacing: -1px;
    }

    .lede {
      max-width: 100%;
      font-size: 15.5px;
    }

    .sec-head {
      margin-top: 72px;
    }

    .row {
      grid-template-columns: 28px 1fr auto;
      gap: 14px;
    }

    .rate {
      gap: 6px;
    }

    .seg {
      width: 13px;
    }

    .rlabel {
      max-width: 52px;
      text-align: right;
    }

    .albgrid {
      grid-template-columns: repeat(4, 1fr);
    }

    .alb .tip {
      display: none;
    }
  }
</style>
